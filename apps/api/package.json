{
  "name": "@sase/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src tests",
    "test": "prisma generate && vitest run",
    "typecheck": "prisma generate && tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:generate:prod": "prisma generate --schema prisma/postgres/schema.prisma",
    "migrate:dev": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy --schema prisma/postgres/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "9.4.0",
    "@fastify/rate-limit": "10.3.0",
    "@prisma/client": "6.19.2",
    "@sase/shared": "0.1.0",
    "dotenv": "17.3.1",
    "fastify": "5.7.4",
    "xlsx": "0.18.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "20.19.33",
    "@types/supertest": "6.0.3",
    "prisma": "6.19.2",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "vitest": "4.0.18"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
